{
  "_comment": "stdio 模式备用配置（v2.36 前）- 当 HTTP 端点不可用时使用",
  "_usage": "复制本文件内容到 .mcp.json 即可切换回 stdio 模式",
  "mcpServers": {
    "MemoryCenter": {
      "command": "ssh",
      "args": [
        "-o", "StrictHostKeyChecking=no",
        "-o", "BatchMode=yes",
        "__REDACTED_SERVER__",
        "MEMORY_CENTER_ROOT=/opt/memory-center-mcp/data /opt/memory-center-mcp/bin/memory-center-mcp"
      ]
    }
  }
}
